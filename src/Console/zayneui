#!/usr/bin/env bash

COMMAND="$1"
COMPONENT_ARG="$2"

find_project_root() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -f "$dir/composer.json" ] && grep -q '"zayne/ui"' "$dir/composer.json" 2>/dev/null; then
            echo "$dir"
            return
        fi
        dir=$(dirname "$dir")
    done
    echo ""
}

PROJECT_ROOT=$(find_project_root)

if [ -z "$PROJECT_ROOT" ]; then
    echo "  ✘ Could not find ZayneUI project root."
    exit 1
fi

STUBS_PHP="$PROJECT_ROOT/stubs/app/View/Components/Zayne"
STUBS_BLADE="$PROJECT_ROOT/stubs/resources/views/components/zayne"

show_help() {
    echo ""
    echo "  ZayneUI CLI"
    echo ""
    echo "  Usage:"
    echo "    ./bin/zayneui make:component <name[/subname]>"
    echo ""
    echo "  Examples:"
    echo "    ./bin/zayneui make:component button"
    echo "    ./bin/zayneui make:component button/group"
    echo "    ./bin/zayneui make:component sidebar/nav-item"
    echo ""
}

to_pascal() {
    local input="$1"
    local result=""
    local part=""

    IFS='-' read -r -a parts <<< "$input"
    for part in "${parts[@]}"; do
        [ -z "$part" ] && continue
        part=$(echo "$part" | tr '[:upper:]' '[:lower:]')
        result="${result}$(echo "${part:0:1}" | tr '[:lower:]' '[:upper:]')${part:1}"
    done

    echo "$result"
}

make_component() {
    if [ -z "$COMPONENT_ARG" ]; then
        echo "  ✘ Missing argument. Usage: ./bin/zayneui make:component <name[/subname]>"
        exit 1
    fi

    if [[ "$COMPONENT_ARG" == */ || "$COMPONENT_ARG" == /* || "$COMPONENT_ARG" == *"//"* ]]; then
        echo "  ✘ Invalid component path: $COMPONENT_ARG"
        exit 1
    fi

    if [[ ! "$COMPONENT_ARG" =~ ^[A-Za-z0-9/-]+$ ]]; then
        echo "  ✘ Component path may only contain letters, numbers, dashes, and slashes."
        exit 1
    fi

    IFS='/' read -r -a RAW_SEGMENTS <<< "$COMPONENT_ARG"

    KEBAB_SEGMENTS=()
    PASCAL_SEGMENTS=()

    for raw in "${RAW_SEGMENTS[@]}"; do
        seg=$(echo "$raw" | tr '[:upper:]' '[:lower:]')

        if [[ ! "$seg" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]]; then
            echo "  ✘ Invalid segment: $raw (use kebab-case words only)"
            exit 1
        fi

        KEBAB_SEGMENTS+=("$seg")
        PASCAL_SEGMENTS+=("$(to_pascal "$seg")")
    done

    SEGMENT_COUNT=${#KEBAB_SEGMENTS[@]}
    LAST_INDEX=$((SEGMENT_COUNT - 1))

    CLASS_NAME="${PASCAL_SEGMENTS[$LAST_INDEX]}"
    FILE_NAME="${CLASS_NAME}.php"
    BLADE_NAME="${KEBAB_SEGMENTS[$LAST_INDEX]}.blade.php"

    PHP_DIR="$STUBS_PHP"
    BLADE_DIR="$STUBS_BLADE"
    NAMESPACE="App\View\Components\Zayne"
    VIEW_PATH="components.zayne"
    USAGE_TAG="x-zayne"
    PHP_DISPLAY_PATH="stubs/app/View/Components/Zayne"
    BLADE_DISPLAY_PATH="stubs/resources/views/components/zayne"

    if [ "$SEGMENT_COUNT" -gt 1 ]; then
        for ((i=0; i<LAST_INDEX; i++)); do
            PHP_DIR="${PHP_DIR}/${PASCAL_SEGMENTS[$i]}"
            BLADE_DIR="${BLADE_DIR}/${KEBAB_SEGMENTS[$i]}"
            NAMESPACE="${NAMESPACE}\\\\${PASCAL_SEGMENTS[$i]}"
            VIEW_PATH="${VIEW_PATH}.${KEBAB_SEGMENTS[$i]}"
            USAGE_TAG="${USAGE_TAG}.${KEBAB_SEGMENTS[$i]}"
            PHP_DISPLAY_PATH="${PHP_DISPLAY_PATH}/${PASCAL_SEGMENTS[$i]}"
            BLADE_DISPLAY_PATH="${BLADE_DISPLAY_PATH}/${KEBAB_SEGMENTS[$i]}"
        done
    fi

    PHP_FILE="$PHP_DIR/$FILE_NAME"
    BLADE_FILE="$BLADE_DIR/$BLADE_NAME"
    VIEW_PATH="${VIEW_PATH}.${KEBAB_SEGMENTS[$LAST_INDEX]}"
    USAGE_TAG="${USAGE_TAG}.${KEBAB_SEGMENTS[$LAST_INDEX]}"

    if [ -f "$PHP_FILE" ]; then
        echo "  ✘ PHP class already exists: $PHP_FILE"
        exit 1
    fi

    if [ -f "$BLADE_FILE" ]; then
        echo "  ✘ Blade file already exists: $BLADE_FILE"
        exit 1
    fi

    mkdir -p "$PHP_DIR"
    mkdir -p "$BLADE_DIR"

    cat > "$PHP_FILE" <<PHP
<?php

namespace ${NAMESPACE};

class ${CLASS_NAME} extends \App\View\Components\Zayne\ZayneComponent
{
    public function __construct(
        //
    ) {
        //
    }

    public function render()
    {
        return view('${VIEW_PATH}');
    }
}
PHP

    cat > "$BLADE_FILE" <<BLADE
<div {{ \$attributes }}>
    {{ \$slot }}
</div>
BLADE

    echo ""
    echo "  ✔ Component created: ${COMPONENT_ARG}"
    echo ""
    echo "    PHP   → ${PHP_DISPLAY_PATH}/${FILE_NAME}"
    echo "    Blade → ${BLADE_DISPLAY_PATH}/${BLADE_NAME}"
    echo ""
    echo "    namespace → ${NAMESPACE}"
    echo "    view()    → '${VIEW_PATH}'"
    echo "    usage     → <${USAGE_TAG} />"
    echo ""
}

case "$COMMAND" in
    make:component) make_component ;;
    help|--help|-h|"") show_help ;;
    *) echo "  ✘ Unknown command: $COMMAND"; show_help; exit 1 ;;
esac
