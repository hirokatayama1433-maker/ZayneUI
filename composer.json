{
    "name": "zayne/ui",
    "description": "A Laravel Blade component library. Install once, own everything.",
    "type": "library",
    "keywords": ["laravel", "blade", "components", "ui", "tailwind"],
    "license": "MIT",
    "authors": [
        {
            "name": "Zayne",
            "email": "zayne@example.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "suggest": {
        "gehrisandro/tailwind-merge-laravel": "Required for class merging in ZayneUI components."
    },
    "require-dev": {
        "orchestra/testbench": "^9.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Zayne\\UI\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Zayne\\UI\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Zayne\\UI\\ZayneServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
